@page "/setup"
@using ContestJudging.Core.Entities

<PageTitle>EOH 2026 - Setup</PageTitle>

<h3>Contest Setup</h3>

<div class="row">
    <div class="col-md-6">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h4>Categories</h4>
            @if (categories.Any())
            {
                <button class="btn btn-outline-danger btn-sm" @onclick="ClearCategories">Clear All</button>
            }
        </div>
        <div class="card p-3 mb-3">
            <EditForm Model="@newCategory" OnValidSubmit="AddCategory">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Rubric Category Name</label>
                    <InputText class="form-control" @bind-Value="newCategory.Id" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Maximum Score</label>
                    <InputNumber class="form-control" @bind-Value="newCategory.MaxScore" />
                </div>
                <button type="submit" class="btn btn-primary">Add Category</button>
            </EditForm>
        </div>

        <ul class="list-group">
            @foreach (var cat in categories)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    @cat.Id (Max: @cat.MaxScore)
                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteCategory(cat.Id)">Delete</button>
                </li>
            }
        </ul>
    </div>

    <div class="col-md-6">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h4>Entries (Teams/Projects)</h4>
            @if (entries.Any())
            {
                <button class="btn btn-outline-danger btn-sm" @onclick="ClearEntries">Clear All</button>
            }
        </div>
        <div class="card p-3 mb-3">
            <EditForm Model="@newEntry" OnValidSubmit="AddEntry">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Entry Name (ID)</label>
                    <InputText class="form-control" @bind-Value="newEntry.Id" />
                </div>
                <button type="submit" class="btn btn-primary">Add Entry</button>
            </EditForm>
        </div>

        <ul class="list-group">
            @foreach (var entry in entries)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    @entry.Id
                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteEntry(entry.Id)">Delete</button>
                </li>
            }
        </ul>
        <div class="card p-3 mb-3 mt-4">
            <h4>Bulk Import Entries</h4>
            <div class="mb-3">
                <label class="form-label">Entry Names (one per line)</label>
                <textarea class="form-control" rows="5" @bind="bulkEntriesText" placeholder="Entry 1&#10;Entry 2&#10;Entry 3"></textarea>
            </div>
            <button class="btn btn-secondary" @onclick="BulkImportEntries">Import Entries</button>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card p-4 shadow-sm border-start border-4 border-info">
            <h4 class="mb-3"><i class="bi bi-diagram-2-fill me-2"></i>Partition Planning</h4>
            <p class="text-muted small">Divide exhibits into groups with "bridge nodes" to ensure statistical connectivity while reducing judge workload.</p>
            
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Judging Groups (k)</label>
                    <input type="number" class="form-control" @bind="kPartitions" min="1" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Overlap Rate (o)</label>
                    <input type="number" class="form-control" @bind="overlapRate" step="0.01" min="0" max="1" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-info text-white w-100" @onclick="GeneratePartitions">
                        Preview Partitions
                    </button>
                </div>
            </div>

            @if (generatedPartitions != null)
            {
                <div class="row mt-4">
                    @foreach (var p in generatedPartitions)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                <div class="card-header bg-light fw-bold">Group @p.Key</div>
                                <div class="card-body py-2">
                                    <ul class="list-unstyled mb-0">
                                        @foreach (var entryId in p.Value)
                                        {
                                            var isBridge = generatedPartitions.Values.Count(v => v.Contains(entryId)) > 1;
                                            <li class="py-1 @(isBridge ? "text-primary fw-bold" : "")">
                                                @if (isBridge) { <i class="bi bi-link-45deg"></i> }
                                                @entryId
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
