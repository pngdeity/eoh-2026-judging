@page "/results"
@using ContestJudging.Core.Entities

<PageTitle>EOH 2026 - Results</PageTitle>

<h3>Results</h3>

<div class="alert alert-info border-start border-4 shadow-sm mb-4">
    <i class="bi bi-info-circle-fill me-2"></i>
    <strong>Statistical Resolution:</strong> Standings are now calculated using the Bradley-Terry model (Maximum Likelihood Estimation) to resolve sparse judging partitions.
</div>

<button class="btn btn-primary mb-3 shadow-sm" @onclick="CalculateResults">
    <i class="bi bi-calculator-fill me-2"></i>Calculate Results
</button>

@if (validationErrors.Any())
{
    <div class="alert alert-warning border-start border-4 shadow-sm mb-4">
        <h4 class="alert-heading fw-bold">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Validation Feedback
        </h4>
        <ul class="mb-0">
            @foreach (var error in validationErrors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@if (leaderboard.Any())
{
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-blue text-white py-3">
            <h4 class="mb-0 fw-bold text-uppercase"><i class="bi bi-trophy-fill me-2"></i>Leaderboard</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Rank</th>
                            <th>Exhibit ID</th>
                            @foreach (var cat in categories)
                            {
                                <th>@cat.Id</th>
                            }
                            <th class="pe-4 text-end">Total Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var item in leaderboard)
                        {
                            <tr class="@(rank == 1 ? "table-success" : "")">
                                <td class="ps-4 fw-bold">#@rank</td>
                                <td class="fw-semibold">@item.Entry.Id</td>
                                @foreach (var cat in categories)
                                {
                                    <td>@item.Entry.Scores.GetValueOrDefault(cat.Id, 0).ToString("N2")</td>
                                }
                                <td class="pe-4 text-end fw-bold text-orange">@item.Entry.TotalScore.ToString("N2")</td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<style>
    .bg-blue {
        background-color: var(--eoh-blue);
    }
    .text-orange {
        color: var(--eoh-orange);
    }
</style>
