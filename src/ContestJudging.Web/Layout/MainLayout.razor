@inherits LayoutComponentBase
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://github.com/pngdeity/eoh-2026-judging/blob/main/README.md" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>

        <footer class="footer py-4 mt-auto">
            <div class="container-fluid px-4">
                <div class="row align-items-center">
                    <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                        <div class="fw-bold text-uppercase small mb-1">Engineering Open House 2026</div>
                        <div class="text-white-50 small">University of Illinois at Urbana-Champaign</div>
                    </div>
                    
                    <div class="col-md-4 text-center mb-3 mb-md-0">
                        <div class="d-flex justify-content-center gap-3">
                            <span class="badge bg-dark-subtle text-white-50 border border-secondary-subtle py-2 px-3">
                                <i class="bi bi-cpu-fill me-1"></i> .NET 10 WASM
                            </span>
                            <span class="badge bg-dark-subtle text-white-50 border border-secondary-subtle py-2 px-3">
                                <i class="bi bi-graph-up-arrow me-1"></i> Bradley-Terry MLE
                            </span>
                        </div>
                    </div>

                    <div class="col-md-4 text-center text-md-end">
                        <a href="https://github.com/pngdeity/eoh-2026-judging" target="_blank" class="github-link text-white text-decoration-none">
                            <i class="bi bi-github fs-3"></i>
                            <span class="d-block small mt-1">Source Code</span>
                        </a>
                    </div>
                </div>
                <hr class="my-4 border-secondary-subtle opacity-25" />
                <div class="text-center text-white-50 smaller">
                    &copy; 2026 EOH Relative Judging System. All Rights Reserved.
                </div>
            </div>
        </footer>
    </main>
</div>
